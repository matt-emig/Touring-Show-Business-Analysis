ALTER TABLE performances
ADD COLUMN tour_id INT
AFTER performance_id;

UPDATE performances p
JOIN (
    SELECT *
    FROM (
        SELECT 
            performance_id,
            DENSE_RANK() OVER (ORDER BY show_id, venue_id) AS tour_id
        FROM performances
    ) ranked
) t
ON p.performance_id = t.performance_id
SET p.tour_id = t.tour_id;

