## Cleaning missing or erroneous values, and creating View to access cleaned data

select * from performances;
select * from costs;
select * from shows;

SELECT 
	p.performance_id,
	CASE
		WHEN p.performance_date BETWEEN s.tour_start_date AND s.tour_end_date THEN p.performance_date
        ELSE NULL
	END AS performance_date_clean
FROM 
	performances p
JOIN
	shows s ON s.show_id = p.show_id;

UPDATE  performances
SET performance_date = '2025-03-29'
WHERE performance_id = 15;

UPDATE performances
SET performance_date = '2025-04-29'
WHERE performance_id = 30;

CREATE OR REPLACE VIEW performances_clean AS
SELECT 
	performance_id,
    tour_id,
    show_id,
    venue_id,
    performance_date,
    CASE
		WHEN tickets_sold > 0 THEN tickets_sold
        ELSE 0
	END AS tickets_sold_clean,
    CASE
		WHEN ticket_price_avg IS NOT NULL THEN ticket_price_avg
        ELSE 0
	END AS ticket_price_avg_clean
FROM
	performances;

SELECT * FROM performances_clean;

## Creating views for EDA of aggregations

CREATE OR REPLACE VIEW aggregations AS
SELECT 
	p.performance_id,
    p.performance_date_clean,
    p.show_id,
    p.venue_id,
	p.tickets_sold_clean * p. ticket_price_avg_clean AS revenue,
    c.travel_cost_clean + c.crew_cost_clean + c.marketing_cost_clean + c.venue_rental_clean AS total_cost,
    (p.tickets_sold_clean * p. ticket_price_avg_clean) - (c.travel_cost_clean + c.crew_cost_clean + c.marketing_cost_clean + c.venue_rental_clean) AS profit,
    CASE
		WHEN p.performance_date_clean IS NULL THEN 'Performance date'
		WHEN p.tickets_sold_clean IS NULL THEN 'Tickets sold'
        WHEN p.ticket_price_avg_clean IS NULL THEN 'Ticket price average'
        WHEN c.travel_cost_clean IS NULL THEN 'Travel cost'
        WHEN c.crew_cost_clean IS NULL THEN 'Crew cost'
        WHEN c.marketing_cost_clean IS NULL THEN 'Marketing cost'
        WHEN c.venue_rental_clean IS NULL THEN 'Venue rental'
        ELSE 'none'
	END AS missing_data
FROM 
	performances_clean p 
    JOIN costs_clean c ON p.performance_id = c.performance_id;
    
SELECT * FROM aggregations;

CREATE OR REPLACE VIEW agg_by_month AS
SELECT
	MONTH(performance_date_clean) AS performance_month,
    SUM(revenue) AS monthly_revenue,
    SUM(total_cost) AS monthly_cost,
    SUM(profit) AS monthly_profit
FROM 
	aggregations
GROUP BY
	MONTH(performance_date_clean);

CREATE OR REPLACE VIEW agg_by_venue AS 
SELECT
	venue_id,
    SUM(revenue) AS venue_revenue,
    SUM(total_cost) AS venue_cost,
    SUM(profit) AS venue_profit
FROM 
	aggregations
GROUP BY
	venue_id
ORDER BY 
	venue_profit DESC;

CREATE OR REPLACE VIEW agg_by_tour AS
SELECT
	s.show_id,
    s.show_name,
    s.tour_start_date,
    s.tour_end_date,
    SUM(a.revenue) AS tour_revenue,
    SUM(a.total_cost) AS tour_cost,
    SUM(a.profit) AS tour_profit
FROM
	shows s
JOIN aggregations a ON s.show_id = a.show_id
GROUP BY 
	s.show_id,
    s.show_name,
    s.tour_start_date,
    s.tour_end_date
ORDER BY 
	tour_profit DESC;

SELECT
	*,
    RANK() OVER (PARTITION BY show_id ORDER BY profit DESC) AS rank_show_profit
FROM
	aggregations;
    
SELECT 
	*
FROM 
	performances p
JOIN
	venues v ON v.venue_id = p.venue_id
WHERE p.tickets_sold > v.capacity;
